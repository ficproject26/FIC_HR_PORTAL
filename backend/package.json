{
  "name": "hr-crm-backend",
  "version": "1.0.0",
  "description": "HR Monitoring and Lead Management CRM Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node config/seed_mongo.js",
    "db:init": "node -e \"require('./config/db'); const fs=require('fs'); const pool=require('./config/db'); pool.query(fs.readFileSync('./config/schema.sql','utf8')).then(()=>{console.log('Schema created');pool.end()}).catch(e=>{console.error(e);pool.end()})\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^9.6.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^2.4.5",
    "socket.io": "^4.6.1",
    "uuid": "^9.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
